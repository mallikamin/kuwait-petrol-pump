# Kuwait Petrol Pump POS - Production Environment Variables
# Copy this file to .env on the production server and fill in actual values

# ============================================================
# Environment
# ============================================================
NODE_ENV=production
PORT=3000

# ============================================================
# Database Configuration
# ============================================================
# PostgreSQL connection URL (will be constructed from individual vars)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# PostgreSQL credentials (CHANGE THESE!)
POSTGRES_USER=petrolpump_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE_32_CHARS_MIN
POSTGRES_DB=petrolpump_production

# ============================================================
# Redis Configuration
# ============================================================
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE_32_CHARS_MIN

# ============================================================
# JWT Configuration
# ============================================================
# Secret key for JWT signing (CHANGE THIS! Use 64+ characters)
JWT_SECRET=CHANGE_ME_VERY_STRONG_JWT_SECRET_AT_LEAST_64_CHARS_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_JWT_REFRESH_SECRET_64_CHARS_MIN
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================================
# CORS Configuration
# ============================================================
# Comma-separated list of allowed origins (production + local dev for UAT testing)
# Production: https://kuwaitpos.duckdns.org
# Local dev: http://localhost:3000, http://localhost:3001, http://localhost:5173
CORS_ORIGIN=https://kuwaitpos.duckdns.org,http://localhost:3000,http://localhost:3001,http://localhost:5173

# ============================================================
# Frontend Configuration
# ============================================================
# Frontend URL for OAuth redirects and other callbacks
FRONTEND_URL=https://kuwaitpos.duckdns.org

# ============================================================
# QuickBooks Integration
# ============================================================
# Get these from QuickBooks Developer Portal
QUICKBOOKS_CLIENT_ID=your-production-quickbooks-client-id
QUICKBOOKS_CLIENT_SECRET=your-production-quickbooks-client-secret
QUICKBOOKS_REDIRECT_URI=https://kuwaitpos.duckdns.org/api/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=production

# ============================================================
# Docker Configuration
# ============================================================
# Docker image to deploy (set by GitHub Actions)
DOCKER_IMAGE=ghcr.io/YOUR_GITHUB_ORG/kuwaitpos-backend:latest

# ============================================================
# Security Notes
# ============================================================
# 1. Generate strong passwords using: pwgen -s 32 1
# 2. Generate JWT secret using: pwgen -s 64 1
# 3. Never commit this file with actual values to Git
# 4. Set file permissions to 600: chmod 600 .env
# 5. Regularly rotate secrets (quarterly)
# 6. Use different secrets for dev/staging/prod environments
