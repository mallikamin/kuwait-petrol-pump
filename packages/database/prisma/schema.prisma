// Kuwait Petrol Pump POS - Database Schema
// Generated: 2026-03-26

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// CORE ENTITIES
// ============================================================

/// Organization (Multi-tenant root entity)
model Organization {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(255)
  currency  String   @default("PKR") @db.VarChar(3)
  timezone  String   @default("Asia/Karachi") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  branches        Branch[]
  users           User[]
  customers       Customer[]
  products        Product[]
  qbConnections   QBConnection[]
  qbSyncQueue     QBSyncQueue[]
  qbSyncLogs      QBSyncLog[]
  qbSnapshots     QBEntitySnapshot[]
  qbEntityMappings QBEntityMapping[]

  @@map("organizations")
}

/// Branch (Petrol pump location)
model Branch {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @db.VarChar(255)
  location       String?  @db.Text
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  organization    Organization     @relation(fields: [organizationId], references: [id])
  dispensingUnits DispensingUnit[]
  users           User[]
  shifts          Shift[]
  shiftInstances  ShiftInstance[]
  sales           Sale[]
  stockLevels     StockLevel[]
  bifurcations    Bifurcation[]

  @@map("branches")
}

// ============================================================
// FUEL MANAGEMENT
// ============================================================

/// Fuel Type (PMG, HSD, etc.)
model FuelType {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String   @db.VarChar(10) // 'PMG', 'HSD'
  name      String   @db.VarChar(100) // 'Petrol', 'Diesel'
  unit      String   @default("liters") @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  prices    FuelPrice[]
  nozzles   Nozzle[]
  fuelSales FuelSale[]

  @@map("fuel_types")
}

/// Fuel Price History
model FuelPrice {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fuelTypeId    String    @map("fuel_type_id") @db.Uuid
  pricePerLiter Decimal   @map("price_per_liter") @db.Decimal(10, 2)
  effectiveFrom DateTime  @map("effective_from") @db.Timestamptz
  effectiveTo   DateTime? @map("effective_to") @db.Timestamptz
  changedBy     String?   @map("changed_by") @db.Uuid
  notes         String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  fuelType      FuelType @relation(fields: [fuelTypeId], references: [id])
  changedByUser User?    @relation(fields: [changedBy], references: [id])

  @@index([fuelTypeId, effectiveFrom, effectiveTo], name: "idx_fuel_prices_effective")
  @@map("fuel_prices")
}

/// Dispensing Unit (Fuel dispenser machine)
model DispensingUnit {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId   String   @map("branch_id") @db.Uuid
  unitNumber Int      @map("unit_number")
  name       String?  @db.VarChar(100) // 'Unit 1', 'Unit A'
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  branch  Branch   @relation(fields: [branchId], references: [id])
  nozzles Nozzle[]

  @@unique([branchId, unitNumber])
  @@map("dispensing_units")
}

/// Nozzle (Fuel nozzle on a dispensing unit)
model Nozzle {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dispensingUnitId String   @map("dispensing_unit_id") @db.Uuid
  nozzleNumber     Int      @map("nozzle_number")
  fuelTypeId       String   @map("fuel_type_id") @db.Uuid
  meterType        String   @default("digital") @map("meter_type") @db.VarChar(20) // 'digital' or 'analog'
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  dispensingUnit DispensingUnit @relation(fields: [dispensingUnitId], references: [id])
  fuelType       FuelType       @relation(fields: [fuelTypeId], references: [id])
  meterReadings  MeterReading[]
  fuelSales      FuelSale[]

  @@unique([dispensingUnitId, nozzleNumber])
  @@map("nozzles")
}

// ============================================================
// USERS & AUTHENTICATION
// ============================================================

/// User (System users with role-based access)
model User {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  branchId       String?  @map("branch_id") @db.Uuid // NULL for org-level users
  username       String   @db.VarChar(100) // Tenant-scoped uniqueness (see @@unique below)
  email          String?  @db.VarChar(255)
  passwordHash   String   @map("password_hash") @db.VarChar(255)
  fullName       String?  @map("full_name") @db.VarChar(255)
  role           String   @db.VarChar(50) // 'admin', 'manager', 'accountant', 'cashier', 'operator'
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  organization     Organization    @relation(fields: [organizationId], references: [id])
  branch           Branch?         @relation(fields: [branchId], references: [id])
  openedShifts     ShiftInstance[] @relation("ShiftOpenedBy")
  closedShifts     ShiftInstance[] @relation("ShiftClosedBy")
  meterReadings    MeterReading[]
  sales            Sale[]
  bifurcations     Bifurcation[]
  auditLogs        AuditLog[]
  fuelPriceChanges FuelPrice[]

  @@unique([organizationId, username], name: "unique_org_username") // Multi-tenant safety
  @@index([organizationId], name: "idx_users_org")
  @@index([role], name: "idx_users_role")
  @@map("users")
}

// ============================================================
// SHIFTS & METER READINGS
// ============================================================

/// Shift (Shift configuration)
model Shift {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId    String   @map("branch_id") @db.Uuid
  shiftNumber Int      @map("shift_number") // 1, 2, 3
  name        String?  @db.VarChar(100) // 'Morning', 'Night'
  startTime   DateTime @map("start_time") @db.Time
  endTime     DateTime @map("end_time") @db.Time
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  branch         Branch          @relation(fields: [branchId], references: [id])
  shiftInstances ShiftInstance[]

  @@map("shifts")
}

/// Shift Instance (Daily shift record)
model ShiftInstance {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shiftId   String    @map("shift_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  date      DateTime  @db.Date
  openedAt  DateTime? @map("opened_at") @db.Timestamptz
  openedBy  String?   @map("opened_by") @db.Uuid
  closedAt  DateTime? @map("closed_at") @db.Timestamptz
  closedBy  String?   @map("closed_by") @db.Uuid
  status    String    @default("pending") @db.VarChar(20) // 'pending', 'open', 'closed'
  notes     String?   @db.Text
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  shift         Shift          @relation(fields: [shiftId], references: [id])
  branch        Branch         @relation(fields: [branchId], references: [id])
  openedByUser  User?          @relation("ShiftOpenedBy", fields: [openedBy], references: [id])
  closedByUser  User?          @relation("ShiftClosedBy", fields: [closedBy], references: [id])
  meterReadings MeterReading[]
  sales         Sale[]
  bifurcations  Bifurcation[]

  @@unique([shiftId, date])
  @@index([branchId, date], name: "idx_shift_instances_date")
  @@map("shift_instances")
}

/// Meter Reading (Fuel meter readings at shift open/close)
model MeterReading {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nozzleId         String   @map("nozzle_id") @db.Uuid
  shiftInstanceId  String   @map("shift_instance_id") @db.Uuid
  readingType      String   @map("reading_type") @db.VarChar(20) // 'opening', 'closing'
  meterValue       Decimal  @map("meter_value") @db.Decimal(12, 2)
  imageUrl         String?  @map("image_url") @db.Text
  ocrResult        Decimal? @map("ocr_result") @db.Decimal(12, 2)
  isManualOverride Boolean  @default(false) @map("is_manual_override")
  recordedBy       String?  @map("recorded_by") @db.Uuid
  recordedAt       DateTime @default(now()) @map("recorded_at") @db.Timestamptz
  // Offline sync tracking (Sprint 1)
  syncStatus       String   @default("pending") @map("sync_status") @db.VarChar(20) // 'pending', 'synced', 'failed'
  offlineQueueId   String?  @map("offline_queue_id") @db.VarChar(100) // Idempotency key (tenant-scoped, see @@unique)
  syncAttempts     Int      @default(0) @map("sync_attempts") @db.Integer
  lastSyncAttempt  DateTime? @map("last_sync_attempt") @db.Timestamptz
  syncError        String?  @map("sync_error") @db.Text
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  nozzle         Nozzle        @relation(fields: [nozzleId], references: [id])
  shiftInstance  ShiftInstance @relation(fields: [shiftInstanceId], references: [id])
  recordedByUser User?         @relation(fields: [recordedBy], references: [id])

  @@unique([nozzleId, offlineQueueId], name: "unique_nozzle_offline_queue") // Multi-tenant safety (nozzle implies org)
  @@index([shiftInstanceId], name: "idx_meter_readings_shift")
  @@index([nozzleId, recordedAt], name: "idx_meter_readings_nozzle")
  @@index([syncStatus, lastSyncAttempt], name: "idx_meter_readings_sync_status")
  @@index([offlineQueueId], name: "idx_meter_readings_offline_queue")
  @@map("meter_readings")
}

// ============================================================
// CUSTOMERS
// ============================================================

/// Customer (Credit customers)
model Customer {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @db.VarChar(255)
  phone          String?  @db.VarChar(50)
  email          String?  @db.VarChar(255)
  address        String?  @db.Text
  vehicleNumbers String[] @map("vehicle_numbers") // Array of vehicle numbers
  creditLimit    Decimal? @map("credit_limit") @db.Decimal(12, 2)
  creditDays     Int?     @map("credit_days")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  sales        Sale[]

  @@index([organizationId], name: "idx_customers_org")
  @@map("customers")
}

// ============================================================
// SALES
// ============================================================

/// Sale (Master transaction record)
model Sale {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId        String    @map("branch_id") @db.Uuid
  shiftInstanceId String?   @map("shift_instance_id") @db.Uuid
  saleDate        DateTime  @default(now()) @map("sale_date") @db.Timestamptz
  saleType        String    @map("sale_type") @db.VarChar(20) // 'fuel', 'non_fuel'
  totalAmount     Decimal   @map("total_amount") @db.Decimal(12, 2)
  taxAmount       Decimal   @default(0) @map("tax_amount") @db.Decimal(12, 2)
  discountAmount  Decimal   @default(0) @map("discount_amount") @db.Decimal(12, 2)
  paymentMethod   String    @map("payment_method") @db.VarChar(50) // 'cash', 'credit', 'card', 'pso_card'
  customerId      String?   @map("customer_id") @db.Uuid
  vehicleNumber   String?   @map("vehicle_number") @db.VarChar(50)
  slipNumber      String?   @map("slip_number") @db.VarChar(100)
  cashierId       String?   @map("cashier_id") @db.Uuid
  qbSynced        Boolean   @default(false) @map("qb_synced")
  qbInvoiceId     String?   @map("qb_invoice_id") @db.VarChar(100)
  qbSyncedAt      DateTime? @map("qb_synced_at") @db.Timestamptz
  // Offline sync tracking (Sprint 1)
  syncStatus      String    @default("pending") @map("sync_status") @db.VarChar(20) // 'pending', 'synced', 'failed'
  offlineQueueId  String?   @map("offline_queue_id") @db.VarChar(100) // Idempotency key (tenant-scoped, see @@unique)
  syncAttempts    Int       @default(0) @map("sync_attempts") @db.Integer
  lastSyncAttempt DateTime? @map("last_sync_attempt") @db.Timestamptz
  syncError       String?   @map("sync_error") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  branch        Branch         @relation(fields: [branchId], references: [id])
  shiftInstance ShiftInstance? @relation(fields: [shiftInstanceId], references: [id])
  customer      Customer?      @relation(fields: [customerId], references: [id])
  cashier       User?          @relation(fields: [cashierId], references: [id])
  fuelSales     FuelSale[]
  nonFuelSales  NonFuelSale[]
  qbSyncLogs    QBSyncLog[]

  @@unique([branchId, offlineQueueId], name: "unique_branch_offline_queue") // Multi-tenant safety (branch implies org)
  @@index([saleDate], name: "idx_sales_date")
  @@index([branchId, saleDate], name: "idx_sales_branch")
  @@index([branchId, syncStatus, lastSyncAttempt], name: "idx_sales_branch_sync") // For 100-pump scale
  @@index([customerId], name: "idx_sales_customer")
  @@index([qbSynced, qbSyncedAt], name: "idx_sales_qb_sync")
  @@index([syncStatus, lastSyncAttempt], name: "idx_sales_sync_status")
  @@index([offlineQueueId], name: "idx_sales_offline_queue")
  @@map("sales")
}

/// Fuel Sale (Fuel sale line items)
model FuelSale {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleId         String   @map("sale_id") @db.Uuid
  nozzleId       String   @map("nozzle_id") @db.Uuid
  fuelTypeId     String   @map("fuel_type_id") @db.Uuid
  quantityLiters Decimal  @map("quantity_liters") @db.Decimal(10, 2)
  pricePerLiter  Decimal  @map("price_per_liter") @db.Decimal(10, 2)
  totalAmount    Decimal  @map("total_amount") @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  sale     Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  nozzle   Nozzle   @relation(fields: [nozzleId], references: [id])
  fuelType FuelType @relation(fields: [fuelTypeId], references: [id])

  @@index([saleId], name: "idx_fuel_sales_sale")
  @@map("fuel_sales")
}

// ============================================================
// INVENTORY
// ============================================================

/// Product (Non-fuel inventory items)
model Product {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  sku               String   @db.VarChar(100)
  name              String   @db.VarChar(255)
  category          String?  @db.VarChar(100)
  barcode           String?  @db.VarChar(100)
  unitPrice         Decimal  @map("unit_price") @db.Decimal(12, 2)
  costPrice         Decimal? @map("cost_price") @db.Decimal(12, 2)
  isActive          Boolean  @default(true) @map("is_active")
  lowStockThreshold Int?     @map("low_stock_threshold")
  qbItemId          String?  @map("qb_item_id") @db.VarChar(100)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  organization Organization  @relation(fields: [organizationId], references: [id])
  stockLevels  StockLevel[]
  nonFuelSales NonFuelSale[]
  qbSyncLogs   QBSyncLog[]

  @@unique([organizationId, sku])
  @@index([organizationId], name: "idx_products_org")
  @@index([barcode], name: "idx_products_barcode")
  @@map("products")
}

/// Stock Level (Inventory levels per branch)
model StockLevel {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  quantity  Int      @default(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  product Product @relation(fields: [productId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@unique([productId, branchId])
  @@index([productId], name: "idx_stock_levels_product")
  @@index([branchId], name: "idx_stock_levels_branch")
  @@map("stock_levels")
}

/// Non-Fuel Sale (Non-fuel sale line items)
model NonFuelSale {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleId      String   @map("sale_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  quantity    Int
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  totalAmount Decimal  @map("total_amount") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId], name: "idx_non_fuel_sales_sale")
  @@map("non_fuel_sales")
}

// ============================================================
// BIFURCATION (Sales Reconciliation)
// ============================================================

/// Bifurcation (Daily sales reconciliation)
model Bifurcation {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId        String    @map("branch_id") @db.Uuid
  date            DateTime  @db.Date
  shiftInstanceId String?   @map("shift_instance_id") @db.Uuid // NULL for end-of-day
  // Fuel totals by type
  pmgTotalLiters  Decimal?  @map("pmg_total_liters") @db.Decimal(10, 2)
  pmgTotalAmount  Decimal?  @map("pmg_total_amount") @db.Decimal(12, 2)
  hsdTotalLiters  Decimal?  @map("hsd_total_liters") @db.Decimal(10, 2)
  hsdTotalAmount  Decimal?  @map("hsd_total_amount") @db.Decimal(12, 2)
  // Payment breakdown
  cashAmount      Decimal?  @map("cash_amount") @db.Decimal(12, 2)
  creditAmount    Decimal?  @map("credit_amount") @db.Decimal(12, 2)
  cardAmount      Decimal?  @map("card_amount") @db.Decimal(12, 2)
  psoCardAmount   Decimal?  @map("pso_card_amount") @db.Decimal(12, 2)
  // Verification
  expectedTotal   Decimal?  @map("expected_total") @db.Decimal(12, 2)
  actualTotal     Decimal?  @map("actual_total") @db.Decimal(12, 2)
  variance        Decimal?  @map("variance") @db.Decimal(12, 2)
  varianceNotes   String?   @map("variance_notes") @db.Text
  bifurcatedBy    String?   @map("bifurcated_by") @db.Uuid
  bifurcatedAt    DateTime? @map("bifurcated_at") @db.Timestamptz
  status          String    @default("pending") @db.VarChar(20) // 'pending', 'completed', 'verified'
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  branch           Branch         @relation(fields: [branchId], references: [id])
  shiftInstance    ShiftInstance? @relation(fields: [shiftInstanceId], references: [id])
  bifurcatedByUser User?          @relation(fields: [bifurcatedBy], references: [id])

  @@unique([branchId, date, shiftInstanceId])
  @@index([branchId, date], name: "idx_bifurcations_date")
  @@map("bifurcations")
}

// ============================================================
// QUICKBOOKS INTEGRATION
// ============================================================

// ---------------------------------------------------------------------------
// TRACK A: Minimum-Safe Sync Foundation (Phase 1)
// Source: POS-Project QB integration (ported from Python to TypeScript/Prisma)
// ---------------------------------------------------------------------------

/// QuickBooks Connection (OAuth2 tokens + health tracking)
model QBConnection {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Organization link
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Connection metadata
  companyName String @map("company_name") @db.VarChar(255)
  realmId     String @map("realm_id") @db.VarChar(50) // QB Online company ID

  // OAuth2 tokens (encrypted with Node crypto AES-256-GCM)
  accessTokenEncrypted  String?   @map("access_token_encrypted") @db.Text
  refreshTokenEncrypted String?   @map("refresh_token_encrypted") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz

  // Connection health
  isActive       Boolean   @default(true) @map("is_active")
  lastSyncAt     DateTime? @map("last_sync_at") @db.Timestamptz
  lastSyncStatus String?   @map("last_sync_status") @db.VarChar(20) // 'success' | 'failed' | 'in_progress'

  // Financial safety controls (Rule 1: Read-only first, Rule 8: Kill switch)
  syncMode         String  @default("READ_ONLY") @map("sync_mode") @db.VarChar(20) // 'READ_ONLY' | 'DRY_RUN' | 'FULL_SYNC'
  globalKillSwitch Boolean @default(false) @map("global_kill_switch") // Emergency stop all syncs
  approvalRequired Boolean @default(true) @map("approval_required") // Require manual approval for write batches

  // Metadata
  connectedBy String   @map("connected_by") @db.Uuid // User ID who connected
  connectedAt DateTime @default(now()) @map("connected_at") @db.Timestamptz
  companyInfo Json?    @map("company_info") @db.JsonB // Cached QB company data

  // Relations
  syncQueue       QBSyncQueue[]
  syncLogs        QBSyncLog[]
  entitySnapshots QBEntitySnapshot[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([organizationId, realmId], name: "uq_qb_conn_org_realm")
  @@index([organizationId, isActive], name: "idx_qb_conn_org_active")
  @@map("qb_connections")
}

/// QuickBooks Sync Queue (Async job queue with retry + idempotency)
model QBSyncQueue {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Connection link
  connectionId String       @map("connection_id") @db.Uuid
  connection   QBConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Job metadata
  jobType    String  @map("job_type") @db.VarChar(50) // 'create_sales_receipt' | 'sync_customer' | 'sync_item'
  entityType String  @map("entity_type") @db.VarChar(50) // 'sale' | 'customer' | 'product'
  entityId   String? @map("entity_id") @db.Uuid

  // Priority and status
  priority Int    @default(5) @db.Integer // 0=critical, 5=normal, 10=bulk
  status   String @default("pending") @db.VarChar(20) // 'pending' | 'processing' | 'completed' | 'failed' | 'dead_letter' | 'cancelled'

  // Payload and result
  payload Json? @db.JsonB // Serialized data for sync operation
  result  Json? @db.JsonB // QB API response on success

  // Error tracking (Track A: Error taxonomy)
  errorMessage   String? @map("error_message") @db.Text
  errorCode      String? @map("error_code") @db.VarChar(50) // QB API error code
  errorDetail    Json?   @map("error_detail") @db.JsonB // Full QB error response
  httpStatusCode Int?    @map("http_status_code") @db.Integer // HTTP status from QB API

  // Retry policy (Track A: Exponential backoff)
  retryCount  Int       @default(0) @map("retry_count") @db.Integer
  maxRetries  Int       @default(3) @map("max_retries") @db.Integer
  nextRetryAt DateTime? @map("next_retry_at") @db.Timestamptz

  // Timing
  startedAt   DateTime? @map("started_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  durationMs  Int?      @map("duration_ms") @db.Integer

  // Idempotency (Track A: DB constraint enforcement)
  idempotencyKey String? @map("idempotency_key") @db.VarChar(100)

  // Financial safety controls (Rule 4: Pre-sync checkpoint, Rule 8: Replay)
  batchId             String?   @map("batch_id") @db.Uuid // Group related operations for atomic approval
  checkpointId        String?   @map("checkpoint_id") @db.Uuid // DB backup checkpoint before execution
  approvalStatus      String    @default("pending_approval") @map("approval_status") @db.VarChar(20) // 'pending_approval' | 'approved' | 'rejected'
  approvedBy          String?   @map("approved_by") @db.Uuid // User who approved the write operation
  approvedAt          DateTime? @map("approved_at") @db.Timestamptz
  replayableFromBatch String?   @map("replayable_from_batch") @db.Uuid // Reference to batch for replay capability

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([organizationId, idempotencyKey], name: "uq_qb_sync_queue_org_idempotency")
  @@index([organizationId, status, priority], name: "idx_qb_sync_queue_org_status_prio")
  @@index([organizationId, nextRetryAt], name: "idx_qb_sync_queue_org_retry")
  @@index([status, createdAt], name: "idx_qb_sync_queue_status_created")
  @@index([organizationId, batchId], name: "idx_qb_sync_queue_org_batch")
  @@index([organizationId, approvalStatus], name: "idx_qb_sync_queue_org_approval")
  @@index([checkpointId], name: "idx_qb_sync_queue_checkpoint")
  @@map("qb_sync_queue")
}

/// QuickBooks Sync Log (Enhanced audit trail with error taxonomy + timing)
model QBSyncLog {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Connection link (Track A addition)
  connectionId String?       @map("connection_id") @db.Uuid
  connection   QBConnection? @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Entity tracking
  entityType String @map("entity_type") @db.VarChar(50) // 'sale', 'customer', 'product'
  entityId   String @map("entity_id") @db.Uuid
  operation  String @db.VarChar(20) // 'create', 'update', 'delete'

  // QB entity ID
  qbId        String? @map("qb_id") @db.VarChar(100)
  qbDocNumber String? @map("qb_doc_number") @db.VarChar(50) // Sales receipt number, invoice number, etc.

  // Status (Track A: Enhanced states)
  status String @db.VarChar(20) // 'success' | 'failed' | 'skipped' | 'partial'

  // HTTP details (Track A: Full audit trail)
  httpMethod     String? @map("http_method") @db.VarChar(10) // 'GET' | 'POST' | 'PUT'
  httpUrl        String? @map("http_url") @db.VarChar(500)
  httpStatusCode Int?    @map("http_status_code") @db.Integer

  // Request/Response (Track A: Full payload logging)
  requestPayload  Json? @map("request_payload") @db.JsonB
  responsePayload Json? @map("response_payload") @db.JsonB

  // Error tracking (Track A: Error taxonomy)
  errorMessage String? @map("error_message") @db.Text
  errorCode    String? @map("error_code") @db.VarChar(50) // QB API error code
  errorDetail  Json?   @map("error_detail") @db.JsonB

  // Timing (Track A: Performance tracking)
  durationMs Int? @map("duration_ms") @db.Integer

  // Financial tracking (Track A: Audit amounts)
  amountCents Int? @map("amount_cents") @db.Integer // For quick financial audit

  // Batch tracking
  batchId String? @map("batch_id") @db.Uuid // Groups related sync operations

  syncedAt  DateTime? @map("synced_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations (polymorphic - manual resolution needed)
  sale    Sale?    @relation(fields: [entityId], references: [id], map: "qb_sync_log_sale_fkey")
  product Product? @relation(fields: [entityId], references: [id], map: "qb_sync_log_product_fkey")

  @@index([organizationId, status, createdAt], name: "idx_qb_sync_log_org_status")
  @@index([organizationId, entityType, entityId], name: "idx_qb_sync_log_org_entity")
  @@index([organizationId, batchId], name: "idx_qb_sync_log_org_batch")
  @@index([status, createdAt], name: "idx_qb_sync_status")
  @@index([entityType, entityId], name: "idx_qb_sync_entity")
  @@map("qb_sync_log")
}

/// QuickBooks Audit Log (Rule 3: Immutable append-only log for ALL QB operations)
model QuickBooksAuditLog {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Operation tracking
  operation   String  @db.VarChar(100) // 'CREATE', 'UPDATE', 'READ', 'SYNC_START', 'SYNC_COMPLETE', 'BATCH_CREATE', etc.
  entity_type String  @map("entity_type") @db.VarChar(50) // 'Customer', 'Item', 'Invoice', 'sale', 'customer', 'product'
  entity_id   String? @map("entity_id") @db.VarChar(100) // QB ID or local UUID

  // Direction and status
  direction String @db.VarChar(20) // 'APP_TO_QB' | 'QB_TO_APP'
  status    String @db.VarChar(20) // 'SUCCESS' | 'FAILURE' | 'PENDING'

  // Payloads (redacted for security)
  request_payload  Json?   @map("request_payload") @db.JsonB
  response_payload Json?   @map("response_payload") @db.JsonB
  error_message    String? @map("error_message") @db.Text

  // Metadata
  metadata Json? @db.JsonB

  created_at DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([operation, created_at], name: "idx_qb_audit_operation_time")
  @@index([entity_type, entity_id], name: "idx_qb_audit_entity")
  @@index([status, created_at], name: "idx_qb_audit_status_time")
  @@index([created_at], name: "idx_qb_audit_created")
  @@map("quickbooks_audit_log")
}

/// QuickBooks Entity Snapshot (Rule 5: QB fallback snapshots for disaster recovery)
model QBEntitySnapshot {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Connection link
  connectionId String       @map("connection_id") @db.Uuid
  connection   QBConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // QB entity identification
  qbEntityType String @map("qb_entity_type") @db.VarChar(50) // 'Customer' | 'Item' | 'Invoice' | 'Payment' | 'Account'
  qbEntityId   String @map("qb_entity_id") @db.VarChar(50) // QuickBooks ID (not our UUID)
  qbEntityName String @map("qb_entity_name") @db.VarChar(255) // For quick reference

  // Local entity mapping (optional)
  localEntityType String? @map("local_entity_type") @db.VarChar(50) // 'customer' | 'product' | 'sale'
  localEntityId   String? @map("local_entity_id") @db.Uuid // Our local ID

  // Full QB entity data (immutable snapshot)
  snapshotData Json    @map("snapshot_data") @db.JsonB // Complete QB entity JSON response
  syncVersion  Int     @default(1) @map("sync_version") @db.Integer // Incremental version tracking
  syncHash     String? @map("sync_hash") @db.VarChar(64) // SHA-256 of snapshot data for change detection

  // Snapshot metadata
  snapshotType String  @map("snapshot_type") @db.VarChar(20) // 'pre_sync' | 'post_sync' | 'manual' | 'scheduled'
  snapshotBy   String? @map("snapshot_by") @db.Uuid // User ID if manual snapshot
  notes        String? @db.Text // Admin notes about this snapshot

  // Timing
  snapshotAt DateTime @map("snapshot_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Retention (for cleanup jobs)
  expiresAt DateTime? @map("expires_at") @db.Timestamptz // Null = keep forever

  @@index([organizationId, qbEntityType, qbEntityId], name: "idx_qb_snapshot_org_entity")
  @@index([organizationId, snapshotType, snapshotAt], name: "idx_qb_snapshot_org_type_time")
  @@index([connectionId, snapshotAt], name: "idx_qb_snapshot_conn_time")
  @@index([expiresAt], name: "idx_qb_snapshot_expires") // For cleanup jobs
  @@map("qb_entity_snapshots")
}

/// QuickBooks Entity Mapping (Local entity ID → QB entity ID mappings)
model QBEntityMapping {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Organization link
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Entity type (customer, payment_method, item)
  entityType String @map("entity_type") @db.VarChar(50)

  // Local entity ID (from Kuwait POS system)
  localId String @map("local_id") @db.VarChar(100)

  // QuickBooks entity ID
  qbId String @map("qb_id") @db.VarChar(100)

  // QuickBooks entity name (for display/reference)
  qbName String? @map("qb_name") @db.VarChar(255)

  // Active status
  isActive Boolean @default(true) @map("is_active")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Unique constraints for data integrity
  @@unique([organizationId, entityType, localId], name: "uq_qb_mapping_org_type_local")
  @@unique([organizationId, entityType, qbId], name: "uq_qb_mapping_org_type_qb")
  @@index([organizationId, entityType], name: "idx_qb_mapping_org_type")
  @@index([organizationId, isActive], name: "idx_qb_mapping_org_active")
  @@map("qb_entity_mappings")
}

